<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- HttpClient wire + headers -->
    <logger name="org.apache.hc.client5" level="DEBUG"/>
    <logger name="org.apache.hc.client5.http.wire" level="DEBUG"/>
    <logger name="org.apache.hc.client5.http.headers" level="DEBUG"/>

    <!-- SPNEGO / Kerberos auth -->
    <logger name="org.apache.hc.client5.http.impl.auth" level="DEBUG"/>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
